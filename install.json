{
  "title": "Install Fish Fin Voice",
  "description": "Konfiguruje repozytorium, lokalne venv Python 3.10 oraz zaleznosci Python i Node.js na Windows, Linux i macOS.",
  "env": {
    "app_dir": "{{path.this}}",
    "venv_dir": "{{path.resolve(path.this, 'venv')}}",
    "requirements_file": "{{path.resolve(path.this, 'requirements.txt')}}"
  },
  "run": [
    {
      "id": "clone-repo-if-needed",
      "method": "git.clone",
      "params": {
        "url": "https://github.com/koloda1988-jpg/Fish_s2_pro_polish.git",
        "path": "{{path.this}}",
        "skipIfExists": true
      }
    },
    {
      "id": "create-python-venv",
      "method": "shell.run",
      "params": {
        "path": "{{path.this}}",
        "message": "{{platform === 'win32' ? 'python -m venv \"' + path.resolve(path.this, 'venv') + '\"' : 'python3 -m venv \"' + path.resolve(path.this, 'venv') + '\"'}}"
      }
    },
    {
      "id": "install-python-requirements",
      "method": "shell.run",
      "params": {
        "path": "{{path.this}}",
        "message": "{{platform === 'win32' ? '\\"' + path.resolve(path.this, 'venv', 'Scripts', 'python.exe') + '\\" -m pip install -r \\"' + path.resolve(path.this, 'requirements.txt') + '\\"' : '\\"' + path.resolve(path.this, 'venv', 'bin', 'python') + '\\" -m pip install -r \\"' + path.resolve(path.this, 'requirements.txt') + '\\"'}}"
      }
    },
    {
      "id": "install-node-dependencies",
      "method": "shell.run",
      "params": {
        "path": "{{path.this}}",
        "message": "npm install"
      }
    }
  ]
}