{
  "title": "Install Fish Fin Voice",
  "description": "Konfiguruje oficjalny flow Pinokio: Conda + Pip + Npm.",
  "env": {
    "app_dir": "{{path.this}}",
    "env_dir": "{{path.resolve(path.this, 'env')}}",
    "requirements_file": "{{path.resolve(path.this, 'requirements.txt')}}"
  },
  "pre": [],
  "run": [
    {
      "method": "conda.create",
      "params": {
        "name": "env",
        "version": "3.10"
      }
    },
    {
      "method": "pip.install",
      "params": {
        "name": "env",
        "path": "{{env.requirements_file}}"
      }
    },
    {
      "method": "npm.install",
      "params": {
        "path": "{{env.app_dir}}"
      }
    }
  ],
  "post": []
}
