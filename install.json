{
  "title": "Install Fish Fin Voice",
  "description": "Automatyczna instalacja środowiska i zależności.",
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "python -m venv venv"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\python.exe -m pip install -r requirements.txt' : 'venv/bin/python -m pip install -r requirements.txt'}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\python.exe scripts\\\\pinokio_download_model.py' : 'venv/bin/python scripts/pinokio_download_model.py'}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "npm install"
      }
    }
  ]
}
