{
  "title": "Install Fish Fin Voice",
  "description": "Automatyczna instalacja środowiska i zależności.",
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "python -m venv venv"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'venv\\\\Scripts\\\\activate && pip install -r requirements.txt' : 'source venv/bin/activate && pip install -r requirements.txt'}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "npm install"
      }
    }
  ]
}
