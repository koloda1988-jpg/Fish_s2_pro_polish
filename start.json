{
  "title": "Start Fish Fin Voice",
  "description": "Uruchamia aplikacje Electron z wykorzystaniem srodowiska Conda env.",
  "env": {
    "app_dir": "{{path.this}}",
    "env_dir": "{{path.resolve(path.this, 'env')}}",
    "PINOKIO_CONDA_ENV": "env",
    "PINOKIO_VENV_PYTHON": "{{platform === 'win32' ? path.resolve(path.this, 'env', 'python.exe') : path.resolve(path.this, 'env', 'bin', 'python')}}",
    "PYTHONUNBUFFERED": "1",
    "PYTHONIOENCODING": "utf-8",
    "ELECTRON_DISABLE_SECURITY_WARNINGS": "true"
  },
  "pre": [],
  "run": [
    {
      "id": "start-electron-app",
      "method": "shell.run",
      "params": {
        "path": "{{path.this}}",
        "message": "npm start"
      }
    }
  ],
  "post": []
}