{
  "title": "Start Fish Fin Voice",
  "description": "Uruchamia aplikacje Electron z platform-aware konfiguracja lokalnego venv dla Windows, Linux i macOS.",
  "env": {
    "app_dir": "{{path.this}}",
    "venv_dir": "{{path.resolve(path.this, 'venv')}}",
    "PINOKIO_VENV_PYTHON": "{{platform === 'win32' ? path.resolve(path.this, 'venv', 'Scripts', 'python.exe') : path.resolve(path.this, 'venv', 'bin', 'python')}}",
    "PYTHONUNBUFFERED": "1",
    "PYTHONIOENCODING": "utf-8",
    "ELECTRON_DISABLE_SECURITY_WARNINGS": "true"
  },
  "run": [
    {
      "id": "start-electron-app",
      "method": "shell.run",
      "params": {
        "path": "{{path.this}}",
        "message": "npm start"
      }
    }
  ]
}